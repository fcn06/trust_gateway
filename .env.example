# Global NATS Message Bus
NATS_URL=nats://127.0.0.1:4222

# Public Gateway
GATEWAY_URL=http://127.0.0.1:3002
GATEWAY_PORT=3002

# Agent / MCP Endpoints
SSI_AGENT_ENDPOINT=http://127.0.0.1:8082
CONNECTOR_MCP_URL=http://127.0.0.1:3050

# WebSockets (Frontend configs normally don't need ports separately, but WS is explicit)
GATEWAY_WS_URL=ws://127.0.0.1:3002/ws/wallet

# OpenID4VP JWT Signing Key (Development ONLY)
# To use this in .env, export as a single line with verbatim \n characters:
# "-----BEGIN PRIVATE KEY-----\nMIIEv...-----END PRIVATE KEY-----"
OID4VP_CLIENT_ID="did:jwk:..."
OID4VP_RSA_PEM="-----BEGIN PRIVATE KEY-----\n..."

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3050/oauth/google/callback"

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_WEBHOOK_URL="https://your-public-domain.com"
TELEGRAM_BOT_ENABLED="false"

# LLM Keys
LLM_A2A_API_KEY="your_groq_key_here"
LLM_MCP_API_KEY="your_groq_key_here"

# JWT Signing Secret (REQUIRED — shared across trust_gateway, native_skill_executor,
# and restaurant_state_service). Use a strong random value in production.
# Generate one with: openssl rand -base64 32
JWT_SECRET=""

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:8083"
