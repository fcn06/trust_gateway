# Trust Gateway Configuration
# REQUIRED: Generate a strong secret with: openssl rand -base64 32
JWT_SECRET=
NATS_URL=nats://127.0.0.1:4222

# LLM API Keys
LLM_MCP_API_KEY=your_groq_key_here
LLM_A2A_API_KEY=your_groq_key_here

# Connector URLs
CONNECTOR_MCP_URL=http://127.0.0.1:3050
SKILL_EXECUTOR_URL=http://127.0.0.1:3070
RESTAURANT_SERVICE_URL=http://127.0.0.1:3080

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3050/oauth/google/callback"
