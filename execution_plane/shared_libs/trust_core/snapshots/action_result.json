{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ActionResult",
  "description": "Result returned after a connector executes an action.",
  "type": "object",
  "required": [
    "action_id",
    "connector",
    "output",
    "status"
  ],
  "properties": {
    "action_id": {
      "description": "Correlates back to the original `ActionRequest.action_id`.",
      "type": "string"
    },
    "connector": {
      "description": "Which connector handled the action.",
      "type": "string"
    },
    "external_reference": {
      "description": "Optional external reference from the SaaS system (e.g. Shopify refund ID, Google event ID).",
      "type": [
        "string",
        "null"
      ]
    },
    "output": {
      "description": "Structured output from the connector."
    },
    "status": {
      "description": "Terminal status.",
      "allOf": [
        {
          "$ref": "#/definitions/ActionStatus"
        }
      ]
    }
  },
  "definitions": {
    "ActionStatus": {
      "description": "The terminal status of an executed action.",
      "type": "string",
      "enum": [
        "succeeded",
        "failed"
      ]
    }
  }
}